# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=latent_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=latent_jwt_secret_change_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_OTP_SECRET=latent_otp_secret_different_from_main
JWT_RESET_SECRET=latent_reset_secret_another_different_one

# Razorpay (test mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# OpenWeatherMap (free tier)
OPENWEATHER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Upload
MAX_FILE_SIZE_MB=5
